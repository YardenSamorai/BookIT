# ===========================================
# BookIT Environment Variables
# ===========================================

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_DOMAIN=localhost:3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/bookit

# Auth.js
AUTH_SECRET=your-auth-secret-here
AUTH_URL=http://localhost:3000

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Twilio (SMS + WhatsApp)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_WHATSAPP_NUMBER=whatsapp:+972XXXXXXXXX

# Twilio WhatsApp Content Template SIDs
TWILIO_CONTENT_SID_BOOKING=
TWILIO_CONTENT_SID_REMINDER=
TWILIO_CONTENT_SID_CANCELLATION=
TWILIO_CONTENT_SID_RESCHEDULE=

# Resend (Email)
RESEND_API_KEY=

# Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# S3-Compatible Storage (R2 or S3)
S3_ENDPOINT=
S3_REGION=auto
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=bookit-uploads
S3_PUBLIC_URL=

# Twilio Status Callback (set to your deployed URL)
TWILIO_STATUS_CALLBACK_URL=https://your-domain.com/api/webhooks/twilio-status

# Cron Secret (for Vercel Cron Jobs)
CRON_SECRET=
